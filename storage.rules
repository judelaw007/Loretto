rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // School assets (logos, etc.) — admin upload, all authenticated read
    match /schools/{schoolId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.token.role in ['super_admin', 'admin'];
    }

    // User profile photos — own user upload, all authenticated read
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Application attachments — public upload (for application form)
    match /applications/{applicationId}/{allPaths=**} {
      allow read: if request.auth != null &&
        request.auth.token.role in ['super_admin', 'admin'];
      allow write: if true;
    }
  }
}
